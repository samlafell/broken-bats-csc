{
  "name": "broken-bats-csc",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "wrangler deploy",
    "db:schema": "wrangler d1 execute broken-bats-db --file=worker/db/schema.sql",
    "db:seed": "wrangler d1 execute broken-bats-db --file=worker/db/seed.sql",
    "db:schema:local": "wrangler d1 execute broken-bats-db --local --file=worker/db/schema.sql",
    "db:seed:local": "wrangler d1 execute broken-bats-db --local --file=worker/db/seed.sql",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@cloudflare/vite-plugin": "^1.28.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "hono": "^4.12.8",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "puppeteer": "^24.39.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.13.1",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260313.1",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "wrangler": "^4.73.0"
  }
}
