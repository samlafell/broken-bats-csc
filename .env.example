# These secrets are set via `wrangler secret put` for production.
# For local development, Wrangler uses a .dev.vars file (see Cloudflare docs).

# SHA-256 hash of the Clubhouse (player) password
PLAYER_PASSWORD_HASH="your_sha256_hash_here"

# SHA-256 hash of the Manager's Office (admin) password
ADMIN_PASSWORD_HASH="your_sha256_hash_here"

# Random secret for signing JWT tokens (e.g. openssl rand -hex 32)
JWT_SECRET="your_random_secret_here"
