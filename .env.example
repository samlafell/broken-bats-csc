# These secrets are set via `wrangler secret put` for production.
# For local development, Wrangler uses a .dev.vars file (see Cloudflare docs).

# SHA-256 hash of the Clubhouse (player) password
PLAYER_PASSWORD_HASH="your_sha256_hash_here"

# SHA-256 hash of the Manager's Office (admin) password
ADMIN_PASSWORD_HASH="your_sha256_hash_here"

# Random secret for signing JWT tokens (e.g. openssl rand -hex 32)
JWT_SECRET="your_random_secret_here"

# ---------------------------------------------------------------------------
# Discord Bot  (scripts/discord-bot.mjs — runs on the Mac Mini)
# ---------------------------------------------------------------------------
# 1. Create an app at https://discord.com/developers/applications
# 2. Bot tab → create bot → copy token
# 3. OAuth2 → URL Generator → scopes: bot, applications.commands
#    → permissions: Send Messages, Embed Links
# 4. Use the generated URL to invite the bot to your server
# 5. Right-click your server name → Copy Server ID → paste as GUILD_ID

DISCORD_BOT_TOKEN="your_discord_bot_token_here"
DISCORD_GUILD_ID="your_discord_server_id_here"

# ---------------------------------------------------------------------------
# Field Bot / Ad-hoc Scraper  (used by both daily and Discord-triggered scrapes)
# ---------------------------------------------------------------------------
ADMIN_PASSWORD="your_admin_password_here"
SITE_URL="https://cscbrokenbats.org"
